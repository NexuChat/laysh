{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://laysh.local/schemas/scene-geometry-1.0.json",
  "title": "Laysh shared scene geometry samples v1.0",
  "type": "array",
  "minItems": 1,
  "items": {"$ref": "#/$defs/sample"},
  "$defs": {
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "phase", "viewport", "state", "objects", "relations"],
      "properties": {
        "schemaVersion": {"type": "string", "enum": ["1.0"]},
        "phase": {"type": "string", "enum": ["candidate", "clamped", "post_fit"]},
        "viewport": {"$ref": "#/$defs/viewport"},
        "state": {"$ref": "#/$defs/state"},
        "objects": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/object"}
        },
        "relations": {
          "type": "array",
          "items": {"$ref": "#/$defs/relation"}
        }
      }
    },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": {"type": "number", "exclusiveMinimum": 0},
        "height": {"type": "number", "exclusiveMinimum": 0},
        "safeInset": {"type": "number", "minimum": 0, "default": 0}
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "timeMs"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "timeMs": {"type": "number", "minimum": 0}
      }
    },
    "object": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "geometry"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "scientific": {"type": "boolean", "default": true},
        "geometry": {"$ref": "#/$defs/circle"},
        "clippingPolicy": {
          "type": "string",
          "enum": ["forbid", "allow"],
          "default": "forbid"
        }
      }
    },
    "circle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "cx", "cy", "radius"],
      "properties": {
        "type": {"type": "string", "enum": ["circle"]},
        "cx": {"type": "number"},
        "cy": {"type": "number"},
        "radius": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["objects"],
      "properties": {
        "objects": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "overlapPolicy": {
          "type": "string",
          "enum": ["forbid", "allow", "scientific_occlusion"],
          "default": "forbid"
        },
        "contactPolicy": {
          "type": "string",
          "enum": ["forbid", "allow", "required"],
          "default": "forbid"
        },
        "minimumClearance": {"type": "number", "minimum": 0, "default": 0}
      }
    }
  }
}
