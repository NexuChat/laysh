{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://laysh.local/schemas/understand-1.0.json",
  "title": "Laysh understanding output v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "safe", "unsafe_category", "simulatable", "reason_code", "lang",
    "canonical_intent", "domain", "title", "tldr", "key_formula",
    "learning_objective", "primary_parameter", "secondary_parameter",
    "prediction", "misconception", "explanation_prompt", "transfer_prompt",
    "module_spec", "checks", "suggestions"
  ],
  "properties": {
    "safe": {"type": "boolean"},
    "unsafe_category": {
      "type": ["string", "null"],
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "sexual_minors", "self_harm", "graphic_violence", "hate_harassment",
            "wrongdoing", "personal_data", "medical"
          ]
        },
        {"type": "null"}
      ]
    },
    "simulatable": {"type": "boolean"},
    "reason_code": {"type": "string", "pattern": "^[a-z0-9_]+$", "maxLength": 64},
    "lang": {"type": "string", "enum": ["ar", "en"]},
    "canonical_intent": {"type": "string", "pattern": "^[a-z0-9_]+$", "maxLength": 100},
    "domain": {"type": "string", "pattern": "^[a-z0-9_]+$", "maxLength": 64},
    "title": {"type": "string", "maxLength": 120},
    "tldr": {"type": "string", "maxLength": 420},
    "key_formula": {
      "type": ["string", "null"],
      "anyOf": [{"type": "string", "maxLength": 120}, {"type": "null"}]
    },
    "learning_objective": {"type": "string", "maxLength": 220},
    "primary_parameter": {
      "type": ["object", "null"],
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "label", "unit", "min", "max", "default", "step"],
          "properties": {
            "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
            "label": {"type": "string", "maxLength": 80},
            "unit": {"type": "string", "maxLength": 24},
            "min": {"type": "number"},
            "max": {"type": "number"},
            "default": {"type": "number"},
            "step": {"type": "number", "exclusiveMinimum": 0}
          }
        }
      ]
    },
    "secondary_parameter": {
      "type": ["object", "null"],
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "label", "unit", "min", "max", "default", "step"],
          "properties": {
            "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
            "label": {"type": "string", "maxLength": 80},
            "unit": {"type": "string", "maxLength": 24},
            "min": {"type": "number"},
            "max": {"type": "number"},
            "default": {"type": "number"},
            "step": {"type": "number", "exclusiveMinimum": 0}
          }
        }
      ]
    },
    "prediction": {
      "type": ["object", "null"],
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["prompt", "choices"],
          "properties": {
            "prompt": {"type": "string", "maxLength": 180},
            "choices": {
              "type": "array",
              "minItems": 2,
              "maxItems": 3,
              "items": {"type": "string", "maxLength": 80}
            }
          }
        }
      ]
    },
    "misconception": {
      "type": ["string", "null"],
      "anyOf": [{"type": "string", "maxLength": 180}, {"type": "null"}]
    },
    "explanation_prompt": {
      "type": ["string", "null"],
      "anyOf": [{"type": "string", "maxLength": 180}, {"type": "null"}]
    },
    "transfer_prompt": {
      "type": ["string", "null"],
      "anyOf": [{"type": "string", "maxLength": 180}, {"type": "null"}]
    },
    "module_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outputs"],
      "properties": {
        "outputs": {
          "type": "array",
          "maxItems": 8,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
        }
      }
    },
    "checks": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "anyOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "kind", "inputs", "output", "expected", "tolerance", "unit"],
            "properties": {
              "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
              "kind": {"type": "string", "enum": ["numeric"]},
              "inputs": {
                "type": "array",
                "minItems": 1,
                "maxItems": 8,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "value"],
                  "properties": {
                    "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
                    "value": {"type": "number"}
                  }
                }
              },
              "output": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
              "expected": {"type": "number"},
              "tolerance": {"type": "number", "minimum": 0},
              "unit": {"type": "string", "maxLength": 24}
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id", "kind", "left_inputs", "right_inputs", "output", "relation", "minimum_ratio"
            ],
            "properties": {
              "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
              "kind": {"type": "string", "enum": ["relation"]},
              "left_inputs": {
                "type": "array",
                "minItems": 1,
                "maxItems": 8,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "value"],
                  "properties": {
                    "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
                    "value": {"type": "number"}
                  }
                }
              },
              "right_inputs": {
                "type": "array",
                "minItems": 1,
                "maxItems": 8,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "value"],
                  "properties": {
                    "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
                    "value": {"type": "number"}
                  }
                }
              },
              "output": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
              "relation": {
                "type": "string",
                "enum": ["right_gt_left", "right_lt_left", "right_eq_left"]
              },
              "minimum_ratio": {"type": "number", "exclusiveMinimum": 0}
            }
          }
        ]
      }
    },
    "suggestions": {
      "type": "array",
      "maxItems": 3,
      "items": {"type": "string", "maxLength": 160}
    }
  }
}
