{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://laysh.local/schemas/verification-report-1.0.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "passed", "tier", "check_count", "heal_count", "checks", "assumptions"],
  "properties": {
    "contract_version": {"const": "1.0"},
    "passed": {"type": "boolean"},
    "tier": {"enum": ["A", "B", "answer_only"]},
    "check_count": {"type": "integer", "minimum": 0},
    "heal_count": {"type": "integer", "minimum": 0, "maximum": 2},
    "checks": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "passed", "evidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "passed": {"type": "boolean"},
          "evidence": {"type": "string", "maxLength": 180}
        }
      }
    },
    "assumptions": {"type": "array", "maxItems": 8, "items": {"type": "string", "maxLength": 180}}
  }
}
