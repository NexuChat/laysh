{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://laysh.local/schemas/module-1.0.json",
  "title": "Laysh generated module output v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["module_js", "output_names", "brief_summary", "assumptions"],
  "properties": {
    "module_js": {"type": "string", "minLength": 1, "maxLength": 40960},
    "output_names": {"type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}},
    "brief_summary": {"type": "string", "maxLength": 240},
    "assumptions": {"type": "array", "maxItems": 8, "items": {"type": "string", "maxLength": 180}}
  }
}

